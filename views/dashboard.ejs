<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Trips — Genesis Transport</title>
  <link rel="icon" type="image/png" href="/css/genesis-logo.png">
  <link rel="stylesheet" href="css/styles.css" />
</head>
<body>

  <div id="site-nav"></div>

  <header class="page-hero" style="padding-bottom:34px;">
    <div class="container">
      <span class="eyebrow" style="background:rgba(212,175,55,0.14);color:var(--gold-400);">My Trips</span>
      <h1 class="mt-8" id="welcome-heading">Welcome back</h1>
      <p>Manage upcoming bookings, revisit past trips, and track your travel.</p>
    </div>
  </header>

  <section class="section" style="padding-top:32px;">
    <div class="container">

      <div class="stats-grid" id="stats-grid"></div>

      <div class="dash-tabs">
        <button class="dash-tab active" data-tab="upcoming">Upcoming</button>
        <button class="dash-tab" data-tab="past">Past trips</button>
        <button class="dash-tab" data-tab="favorites">Favorite routes</button>
      </div>

      <div id="tab-upcoming" class="tab-panel">
        <div id="upcoming-list"></div>
      </div>

      <div id="tab-past" class="tab-panel hide">
        <div id="past-list"></div>
      </div>

      <div id="tab-favorites" class="tab-panel hide">
        <div id="favorites-list" class="routes-grid"></div>
      </div>

    </div>
  </section>

  <div id="site-footer"></div>
  <div class="toast"></div>

  <!-- Cancel confirmation dialog -->
  <div id="cancel-modal" class="modal-overlay hide">
    <div class="modal-card">
      <h3>Cancel this booking?</h3>
      <p class="muted">This will release your seat and can't be undone in this prototype.</p>
      <div class="flex gap-12 mt-24">
        <button class="btn btn-ghost btn-block" id="cancel-dismiss">Keep booking</button>
        <button class="btn btn-danger-ghost btn-block" id="cancel-confirm">Cancel booking</button>
      </div>
    </div>
  </div>

  <script src="js/main.js"></script>
  <script src="js/dashboard.js"></script>

  <!-- View Ticket Modal -->
  <div id="ticket-modal" class="modal-overlay hide" style="z-index: 1000; background: rgba(11, 30, 61, 0.7); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; position: fixed; top: 0; left: 0; width: 100%; height: 100%;">
    <div class="modal-card" style="max-width: 440px; width: 90%; padding: 0; background: transparent; box-shadow: none; position: relative;">
      <button id="ticket-close" style="position: absolute; top: 16px; right: 16px; background: rgba(0, 0, 0, 0.05); border: none; border-radius: 50%; width: 32px; height: 32px; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10; color: #333;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
      <div id="ticket-modal-content"></div>
    </div>
  </div>
</body>
</html>
